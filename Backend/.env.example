# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Groq (get a free key at https://console.groq.com)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Sarvam AI (get a key at https://dashboard.sarvam.ai)
SARVAM_API_KEY=your-sarvam-api-key

# JWT
JWT_SECRET_KEY=your-very-secret-jwt-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# App
APP_NAME=Aarogyan
APP_ENV=development
CORS_ORIGINS=http://localhost,http://localhost:3000,http://10.0.2.2
